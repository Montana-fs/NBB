# Kopiér denne fil til .env og udfyld værdierne

# Claude / Anthropic API nøgle (påkrævet for post-skrivning)
ANTHROPIC_API_KEY=sk-ant-...

# LinkedIn (udfyldes når vi er klar til rigtig integration)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_COMPANY_ID=

# Email godkendelse (udfyldes når vi er klar til rigtig integration)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
APPROVAL_EMAIL=tony.andersen@zentura.dk

# Dummy-tilstand: sæt til "true" for at køre uden rigtige integrationer
DUMMY_MODE=true
